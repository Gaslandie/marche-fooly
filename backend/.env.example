# Environnement d'execution.
# En local: laisser "development" (ou ne pas definir).
# En production (Render): definir NODE_ENV=production.
NODE_ENV=development

PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/marche-fooly?retryWrites=true&w=majority&appName=marcheFoolyBackend

# Authentification
# Generer une chaine longue et aleatoire (>=32 caracteres). Ex: `openssl rand -hex 48`
JWT_SECRET=change-me-please-set-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# CORS - origines frontend autorisees (separees par des virgules)
CORS_ORIGIN=http://localhost:3000

# Migration controlee du compte proprietaire:
# OWNER_EMAIL=proprietaire@marchefooly.com npm run owner:promote
OWNER_EMAIL=proprietaire@marchefooly.com

# Upload images produits (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRODUCT_FOLDER=marche-fooly/products

# Notifications email (SMTP)
# Laisser NOTIFICATION_EMAIL_ENABLED=false tant que SMTP n'est pas configure.
NOTIFICATION_EMAIL_ENABLED=false
APP_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Marche Fooly <contact@marchefooly.com>"
SMTP_REPLY_TO=contact@marchefooly.com

# URL publique du frontend, SANS slash final. Utilisee pour construire les
# liens dans les emails (reinitialisation de mot de passe, notifications).
# En production: l'URL reelle du site (ex. https://www.marchefooly.com).
APP_URL=http://localhost:3000
