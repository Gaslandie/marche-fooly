PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/marche-fooly?retryWrites=true&w=majority&appName=marcheFoolyBackend

# Authentification
# Generer une chaine longue et aleatoire (>=32 caracteres). Ex: `openssl rand -hex 48`
JWT_SECRET=change-me-please-set-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# CORS - origines frontend autorisees (separees par des virgules)
CORS_ORIGIN=http://localhost:3000
